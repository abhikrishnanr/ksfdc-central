DATABASE_URL=
LOCAL_THEATRE_API_URL=https://tvm001-local-api.webtestingonline.com
LOCAL_THEATRE_SHARED_SECRET=
CLOUDFLARE_ACCESS_CLIENT_ID=
CLOUDFLARE_ACCESS_CLIENT_SECRET=
NEXT_PUBLIC_APP_NAME=KSFDC Central Booking
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_ENABLED=true
ALLOW_SIMULATED_PAYMENT_FALLBACK=false

# Central MySQL fallback settings used by lib/db.ts when DATABASE_URL is not set.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ksfdc_central

# Server-only auth/session settings. Use long random values in production.
AUTH_COOKIE_SECRET=replace-with-long-random-secret
SESSION_SECRET=replace-me
JWT_SECRET=replace-me

# Optional tuning and legacy compatibility.
LOCAL_TUNNEL_TIMEOUT_MS=3500
LOCAL_HEALTH_CHECK_TIMEOUT_MS=10000
LOCAL_SEAT_STATUS_TIMEOUT_MS=10000
AUTHORITY_HEARTBEAT_INTERVAL_SEC=10
LOCAL_THEATRE_CLIENT_ID=central-app
LOCAL_SHARED_SECRET=
KSFDC_HMAC_SECRET=
ALLOW_INSECURE_DEV_HMAC=false
CLOUDFLARE_ACCESS_REQUIRED=false
